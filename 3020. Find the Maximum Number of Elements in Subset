class Solution {
    public int maximumLength(int[] arr) {
        TreeSet<Integer> set = new TreeSet<>();
        HashMap<Integer,List<Integer>> map = new HashMap<>();
        HashMap<Integer,Integer> freq = new HashMap<>();
        for(int num : arr) {
            set.add(num);
            freq.put(num,freq.getOrDefault(num, 0) + 1);
        }
        int ans = 1;
        for(int num : set) {
            if(num == 1) {continue;}
            int sqrt = (int)Math.sqrt(num);
            if(!map.containsKey(sqrt)) {
                map.put(num,new ArrayList<>());
                map.get(num).add(num);
            }else{
                if(sqrt * sqrt != num) {continue;}
                List<Integer> update = new ArrayList<>(map.get(sqrt));
                if(freq.get(update.getLast()) < 2) {
                    if(update.size() > 1) {
                        ans = Math.max(ans,update.size() * 2 - 1);
                    }
                    map.remove(sqrt);
                    map.put(num,new ArrayList<>());
                    map.get(num).add(num);
                }else{
                    update.add(num);
                    map.remove(sqrt);
                    map.put(num, update);
                }
            }
        }
        for(int key : map.keySet()) {
            List<Integer> list = map.get(key);
            boolean flag = true;
            if(list.size() < 2) {continue;}
            for(int i = 0;i < list.size();i++) {
                int num = list.get(i);
                if(i != list.size() - 1 && freq.get(num) < 2) {
                    flag = false;
                    break;
                }
            }
            if(flag) {ans = Math.max(ans,list.size() * 2 - 1);}
        }
        System.out.print(map);
        int ones = freq.containsKey(1) ? freq.get(1) : 0;
        if(ones > 0 && ones % 2 == 0) {ones--;}
        ans = Math.max(ans,ones);
        return ans;
    }
}
