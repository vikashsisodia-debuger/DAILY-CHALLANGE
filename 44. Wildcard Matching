class Solution {
    static Boolean[][] dp;
    public boolean isMatch(String s, String p) {
        Stack<Character> stack = new Stack<>();
        for(char ch : p.toCharArray()) {
            if(!stack.isEmpty() && stack.peek() == '*' && ch == '*') {continue;}
            stack.push(ch);
        }
        char ch[] = new char[stack.size()];
        for(int i = stack.size() - 1;i >= 0;i--) {
            ch[i] = stack.pop();
        }
        String newFreshPattern = new String(ch);
        dp = new Boolean[s.length() + 1][newFreshPattern.length()];
        return solve(s,newFreshPattern,0,0);
    }
        static boolean solve(String str,String pattern,int i,int j) {
        if(i == str.length() && j == pattern.length()) {return true;}
        if(j == pattern.length() && i < str.length()) {return false;}
        if(dp[i][j] != null) {
            return dp[i][j];
        }
        if(i >= str.length() && j < pattern.length()) {
            if(pattern.charAt(j) != '*') {
                return dp[i][j] = false;
            }
            return dp[i][j] = solve(str, pattern, i, j + 1);
        }
        if(str.charAt(i) == pattern.charAt(j)) {
            return dp[i][j] = solve(str, pattern, i + 1, j + 1);
        }else if(pattern.charAt(j) == '?') {
            return dp[i][j] = solve(str, pattern, i + 1, j + 1);
        }else if(pattern.charAt(j) == '*') {
            // there are two choices.
            boolean skip = solve(str, pattern, i, j + 1);
            boolean take = false;
            for(int idx = i + 1;idx <= str.length();idx++) {
                take = solve(str, pattern, idx, j + 1);
                if(take) {
                    return dp[i][j] = true;
                }
            }
            return dp[i][j] = take || skip;
        }
        return dp[i][j] = false;
    }
}
